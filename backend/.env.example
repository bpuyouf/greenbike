# Development environment variables
# Copy this file to .env and fill in your real values.

PORT=3000

# Use the default postgres superuser to create the database + user.
# Set these to the credentials of an existing superuser (often 'postgres').
PG_ADMIN_USER=postgres
PG_ADMIN_PASSWORD=your_secure_password

# The app will connect as the user encoded here. Commonly this is the
# same as the admin user (postgres) but can be a separate user.
# For best security, use a dedicated user rather than the superuser.
DATABASE_URL=postgres://postgres:your_secure_password@localhost:5432/greenbike

# Example: enable debug logging
# DEBUG=true
